# Copy to `.env` or `.env.local` and set real values from Supabase → Project Settings → API.
# Leave the two Supabase lines empty (or omit them) to run in demo mode locally.
#
# Do not use README placeholder strings — they are ignored and treated as demo mode.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Enrollment rows in `public.enrollments` require an authenticated session (RLS: auth.uid() = user_id).
# Complete the review step while signed in so the app can call the REST API with your JWT.

# Optional: skip auth + OTP in development only (see ProtectedRoute + ENV.DEMO_MODE)
VITE_DEBUG_BYPASS_AUTH=false

# Optional: use external legal/help URLs (full https://). If unset, /privacy, /terms, and /help are served in-app.
# VITE_PRIVACY_POLICY_URL=
# VITE_TERMS_OF_SERVICE_URL=
# VITE_HELP_CENTER_URL=
