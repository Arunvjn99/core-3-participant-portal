# Local setup — copy this file to `.env.local` in the project root and fill in real values.
# Vite loads `.env.local` automatically (and it is gitignored via `*.local`).
#
# Without `VITE_SUPABASE_URL` and `VITE_SUPABASE_ANON_KEY`, the app runs in demo mode
# (no live Supabase connection; auth helpers return demo errors where applicable).

# Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: skip auth + OTP in development only (see ProtectedRoute + ENV.DEMO_MODE)
VITE_DEBUG_BYPASS_AUTH=false
